# Backend env examples for famora_server_api
# Option A (recommended for local development):
# Set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON file.
# Example (PowerShell): $env:GOOGLE_APPLICATION_CREDENTIALS = 'C:\path\to\serviceAccount.json'
# Then run `npm start`.

# Option B (container-friendly): store service account JSON as a single-line string
# (escape newlines) in FIREBASE_SERVICE_ACCOUNT and set FIREBASE_PROJECT_ID.

# FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "...", ...}
# FIREBASE_PROJECT_ID=your_project_id

# Server port (optional)
PORT=4000
