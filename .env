# Optional: use one of the two credential approaches described in .env.example
# Example for Option B (paste the JSON on a single line, or use proper escaping):
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your_project_id",...}

# Or set GOOGLE_APPLICATION_CREDENTIALS to the path of the JSON file in your environment (not stored here).

# If using FIREBASE_SERVICE_ACCOUNT, also set the project id:
FIREBASE_PROJECT_ID=farmora-3d65b

PORT=4000
